---
import Hero from '~/components/widgets/Hero.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Image from '~/components/common/Image.astro';
import Layout from '~/layouts/PageLayout.astro';
import clinicInteriorHallway from 'public/images/clinic-interior-hallway.png';
import adamAmerFounder from 'public/images/adam-amer-founder.png';

const metadata = {
  title: 'אודותינו - מכון טון',
  description:
    'מכון טון – מרכז אודיולוגי מקצועי. הסיפור שלנו, החזון, והצוות בהובלת אדם עאמר. קביעת תור לבדיקת שמיעה והתאמת מכשירים.',
};
---

<Layout metadata={metadata}>
  <!-- Hero: clinic photo + title only (no service-style two-line headline) -->

  <Hero
    image={{
      src: clinicInteriorHallway,
      alt: 'מכון טון - מסדרון המרפאה והמרחב המקצועי',
    }}
  >
    <Fragment slot="title">אודותינו</Fragment>
    <Fragment slot="subtitle">
      מכון טון נוסדה בשנת 2023 עם מטרה ברורה: לספק טיפול אודיולוגי מתקדם ואיכותי לכל מטופל. הצוות המקצועי שלנו כולל
      אודיולוגים מוסמכים עם ניסיון רב באבחון וטיפול בבעיות שמיעה שונות.
    </Fragment>
    <Fragment slot="content">
      <div
        dir="rtl"
        class="mx-auto my-8 max-w-2xl space-y-5 border-e-4 border-accent pe-6 text-start text-lg leading-relaxed text-muted dark:text-slate-300 md:text-xl"
      >
        <p>
          המכון בניהולו של הקלינאי הוותיק אדם עאמר – שהוא בעל ניסיון נרחב בהתאמת מכשירי שמיעה מכל המותגים והחברות,
          וניהל בשנות עבודתו מספר מכונים מרכזיים בכל רחבי הארץ!
        </p>
        <p>
          אצלנו תקבלו שירות מקצועי, היכרות רבת שנים עם ענף מורכב שדורש הבנה עמוקה, ומכשירי שמיעה ברמות הכי מתקדמות
          לרבות מכשירים נטענים, מכשירים עם חיבור בלוטוס ישיר לטלפון, מכשירים קטנים ואסתטיים.
        </p>
      </div>
    </Fragment>
  </Hero>

  <!-- Vision + portrait: editorial split (only on About) -->

  <WidgetWrapper containerClass="max-w-6xl">
    <div class="grid gap-12 md:grid-cols-[minmax(0,1fr)_260px] md:gap-14 lg:grid-cols-[minmax(0,1fr)_280px]">
      <article dir="rtl" class="min-w-0 space-y-5 text-start text-lg leading-relaxed text-muted dark:text-slate-300 md:text-xl">
        <h2 class="font-heading text-3xl font-bold tracking-tight text-heading dark:text-slate-100 md:text-4xl">החזון שלנו</h2>
        <p>
          במכון טון אנו שואפים להיות הבחירה הראשונה והאמינה ביותר בתחום השמיעה, תוך הענקת שירות מקצועי, אישי ומתקדם לכל
          מטופל, בכל גיל.
        </p>
        <p>
          אנו פועלים מתוך מחויבות לשפר את איכות החיים של לקוחותינו, באמצעות אבחון מדויק של יכולות השמיעה והתאמה מיטבית של
          מכשירי שמיעה מהמתקדמים בעולם.
        </p>
        <p>
          חזוננו הוא לשלב טכנולוגיה חדשנית עם יחס אנושי חם, וליצור חוויית שירות שמבוססת על אמון, שקיפות וליווי מלא לאורך כל
          הדרך.
        </p>
        <p>
          במכון טון, אנו לא רק משפרים שמיעה – אנו מחברים אנשים לעולם של צלילים, תקשורת ואיכות חיים טובה יותר.
        </p>
      </article>

      <aside class="mx-auto w-full max-w-xs shrink-0 self-start md:mx-0 md:max-w-none" dir="rtl">
        <div class="rounded-2xl border border-slate-200/90 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900/80">
          <Image
            src={adamAmerFounder}
            alt="אדם עאמר – מייסד ומנהל מכון טון"
            class="aspect-[3/4] w-full rounded-xl object-cover object-top"
            widths={[280, 400, 560]}
            sizes="(max-width: 767px) 280px, 320px"
            loading="lazy"
            layout="responsive"
          />
          <p class="mt-4 text-center text-lg font-semibold text-heading dark:text-slate-100">אדם עאמר</p>
          <p class="text-center text-sm text-muted dark:text-slate-400">מייסד ומנהל המכון</p>
        </div>
      </aside>
    </div>
  </WidgetWrapper>

  <!-- Why us: simple list, original wording -->

  <WidgetWrapper containerClass="max-w-3xl">
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
    <section dir="rtl">
      <h2 class="mb-6 text-center font-heading text-2xl font-bold text-heading dark:text-slate-100 md:text-3xl">
        אז למה לבחור במכון טון
      </h2>
      <ul class="space-y-4 text-lg text-muted dark:text-slate-300 md:text-xl">
        <li>
          <span class="font-semibold text-heading dark:text-slate-200">קרוב אליכם:</span>
          אנחנו בלב המרכז במקום נגיש עם חנייה והנגשה לכולם
        </li>
        <li>
          <span class="font-semibold text-heading dark:text-slate-200">מקצועי מאוד:</span>
          היכרות רבת שנים עם הענף ומקצועיות עמוקה
        </li>
        <li>
          <span class="font-semibold text-heading dark:text-slate-200">מחירים הכי משתלמים:</span>
          אצלנו תקבלו את ההצעה הכי טובה (לרבות הסכמים עם הקופות)
        </li>
        <li>
          <span class="font-semibold text-heading dark:text-slate-200">שירות אדיב:</span>
          הקשבה והבנה לדרישות הלקוח
        </li>
      </ul>
    </section>
  </WidgetWrapper>

  <ContactUs
    id="form"
    title="מעוניינים לקבוע תור לבדיקת שמיעה או התאמת מכשיר שמיעה?"
    subtitle="מלאו את הטופס ונחזור אליכם בהקדם. לקביעת תור מידית, חייגו אלינו בטלפון 073-3880680"
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'שם מלא',
      },
      {
        type: 'tel',
        name: 'phone',
        label: 'טלפון',
      },
      {
        type: 'email',
        name: 'email',
        label: 'אימייל (אופציונלי)',
      },
      {
        type: 'text',
        name: 'preferred_time',
        label: 'זמן מועדף לתור',
      },
    ]}
    textarea={{
      label: 'פרטים נוספים / סוג הטיפול הנדרש',
    }}
    description="נחזור אליכם בהקדם לקביעת התור. לתגובה מיידית - חייגו 073-3880680"
  />
</Layout>
